# Copy to .env and fill in
OPENAI_API_KEY=sk-...

# Models
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_ROUTER_MODEL=gpt-4o-mini          # cheap model for query rewrite + rerank
OPENAI_EMBED_MODEL=text-embedding-3-small

# RAG
RAG_TOP_K=3
RAG_MIN_SCORE=0.30
RERANK_CANDIDATES=8                       # Qdrant hits fetched before reranking

# Qdrant (vector store) — populate with: python scripts/embed_to_qdrant.py
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=chatbot_sd_kb

# History — chat history is kept client-side (localStorage); this only caps
# how many prior turns the client sends to the LLM for context.
HISTORY_TURNS=6

# Kafka — set KAFKA_ENABLED=true to consume from ai-agent-chat topic
KAFKA_ENABLED=false
KAFKA_HOST=localhost:9092
KAFKA_INPUT_TOPIC=ai-agent-chat
KAFKA_OUTPUT_TOPIC=bot-agent-service
KAFKA_GROUP_ID=ai-agent-consumer

# WebSocket (SocketCluster) — set WS_ENABLED=true to stream tokens to frontend
WS_ENABLED=false
WS_URL=ws://localhost:8001/socketcluster/

# Langfuse — set LANGFUSE_ENABLED=true to trace all LLM calls
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TIMEOUT=5000