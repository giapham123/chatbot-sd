{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Chatbot SD (module)",
      "type": "debugpy",
      "request": "launch",
      "module": "app.main",
      "cwd": "${workspaceFolder}",
      "env": { "DEBUG": "1" },
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Debug: uvicorn (no reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--host", "127.0.0.1", "--port", "8000", "--log-level", "debug"],
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "console": "integratedTerminal"
    }
  ]
}